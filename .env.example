# Copiar a .env (o configurar en Render → Environment) — NO subir .env a git

# Clave de sesión de Flask (generar una aleatoria larga)
SECRET_KEY=cambiar-por-una-clave-aleatoria-larga

# Credenciales del panel /admin
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar-esta-contraseña

# Postgres (Render la provee al crear la base; si no está, usa SQLite local)
# DATABASE_URL=postgres://usuario:pass@host/db

# Cloudinary para imágenes persistentes (plan gratis en cloudinary.com)
# Se copia desde el dashboard de Cloudinary. Si no está, guarda en static/uploads
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
